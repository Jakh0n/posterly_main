# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Supabase (service role key is secret — never expose to the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI providers
OPENAI_API_KEY=your-openai-api-key
FAL_KEY=your-fal-key

# Cloudflare R2 storage
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-r2-bucket
R2_PUBLIC_URL=https://your-r2-public-url

# Polar billing
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret

# Shared secret the frontend sends to enqueue generation jobs (x-worker-secret).
# Optional in dev; required in production to lock down POST /api/v1/jobs/generate.
WORKER_SECRET=your-worker-secret

# Set to "true" to render local placeholder images instead of calling fal.
# Also implied when FAL_KEY is a placeholder. Dev/test only.
MOCK_GENERATION=false
